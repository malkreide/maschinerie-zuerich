{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":timezone(Europe/Zurich)",
    ":dependencyDashboard",
    ":semanticCommitType(deps)",
    ":semanticCommitScope(deps)"
  ],
  "description": "Renovate-Config für malkreide/maschinerie-zuerich. Ersetzt Dependabot.",
  "schedule": ["before 5am on monday"],
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 8,
  "packageRules": [
    {
      "description": "Gruppiert React-Familie + Types in einem PR",
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "/^@types/react/"
      ],
      "groupName": "react"
    },
    {
      "description": "Gruppiert alle d3-Module + Types",
      "matchPackageNames": [
        "/^d3-/",
        "/^@types/d3-/"
      ],
      "groupName": "d3"
    },
    {
      "description": "Gruppiert Tailwind + PostCSS",
      "matchPackageNames": [
        "tailwindcss",
        "postcss",
        "/^@tailwindcss//"
      ],
      "groupName": "tailwind"
    },
    {
      "description": "Gruppiert Cytoscape + Plugins",
      "matchPackageNames": [
        "cytoscape",
        "/^cytoscape-/"
      ],
      "groupName": "cytoscape"
    },
    {
      "description": "Gruppiert TypeScript-Tooling",
      "matchPackageNames": [
        "typescript",
        "@types/node"
      ],
      "groupName": "tooling"
    },
    {
      "description": "Gruppiert GitHub Actions Updates monatlich",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "schedule": ["before 5am on the first day of the month"]
    },
    {
      "description": "Auto-Merge: Patch- und Minor-Updates von devDependencies — mit Cooldown, damit ein frisch kompromittiertes Release nicht ungesehen einläuft (npm-Hijacks werden meist innert Tagen entdeckt/gezogen)",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeStrategy": "squash",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Runtime-Deps: KEIN Auto-Merge — main wird via docker-publish.yml automatisch als :latest veröffentlicht, ein kompromittiertes Patch-Release ginge sonst ohne menschliches Review live",
      "matchDepTypes": ["dependencies"],
      "automerge": false,
      "minimumReleaseAge": "3 days",
      "addLabels": ["runtime-dep"]
    },
    {
      "description": "Major-Updates: manuell prüfen (Breaking-Change-Risiko)",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    },
    {
      "description": "Lock-File-Maintenance: KEIN Auto-Merge — refresht transitive Runtime-Deps und ist damit derselbe Supply-Chain-Pfad wie direkte Runtime-Updates",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "automerge": true,
    "automergeStrategy": "squash"
  },
  "configMigration": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "platformAutomerge": true
}
