{
  "$schema": "../../../schemas/opengov-process-schema.json",
  "id": "anwohnerparkkarte",
  "version": "0.1.0",
  "city": "zh",
  "titel": {
    "de": "Anwohnerparkkarte (blaue Zone)",
    "en": "Resident parking permit (blue zone)",
    "fr": "Carte de stationnement pour riverains (zone bleue)",
    "it": "Carta di parcheggio per residenti (zona blu)",
    "ls": "Park-Karte für deine Strasse (blaue Zone)"
  },
  "kurzbeschreibung": {
    "de": "Ablauf für den Bezug einer Anwohnerparkkarte in der Stadt Zürich. Berechtigt zum Dauerparkieren in der eigenen blauen Zone. Seit 2023 rein digital: das Kontrollschild wird im System hinterlegt, es gibt keine physische Karte mehr.",
    "en": "Process for obtaining a resident parking permit in the City of Zurich. Grants permanent parking rights within one's own blue zone. Fully digital since 2023 — the licence plate is registered in the control system, no physical badge.",
    "ls": "Du wohnst in einer blauen Zone. Du hast ein Auto. Dann kannst du eine Park-Karte kaufen. Damit darfst du in deiner Strasse parkieren, so lange du willst. Die Karte ist digital. Die Polizei liest dein Kennzeichen."
  },
  "rechtsgrundlagen": [
    { "bezeichnung": "Verkehrsreglement der Stadt Zürich (VRSZ)", "url": "https://www.stadt-zuerich.ch/pd/de/index/das_departement/organisation/dienstabteilungen/dav.html" },
    { "bezeichnung": "SVG Art. 3 (Strassenverkehrsgesetz)", "url": "https://www.fedlex.admin.ch/eli/cc/1959/679_705_725/de" },
    { "bezeichnung": "Signalisationsverordnung SSV Art. 48", "url": "https://www.fedlex.admin.ch/eli/cc/1979/1961_1961_1961/de" }
  ],
  "quellen": [
    {
      "id": "q-stz-parkkarten",
      "titel": "Stadt Zürich – Parkkarten-Angebote",
      "url": "https://www.stadt-zuerich.ch/pd/de/index/dav/parkkarten.html",
      "abgerufen": "2026-04-24"
    },
    {
      "id": "q-stz-online",
      "titel": "Stadt Zürich – Parkkarten-Online-Portal",
      "url": "https://www.stadt-zuerich.ch/pd/de/index/dav/parkkarten/anwohnerparkkarten.html",
      "abgerufen": "2026-04-24"
    }
  ],
  "akteure": [
    {
      "id": "halter",
      "label": {
        "de": "Fahrzeughalter:in (Anwohner:in)",
        "en": "Vehicle holder (resident)",
        "fr": "Détenteur du véhicule (riverain)",
        "it": "Detentore del veicolo (residente)",
        "ls": "Du (du wohnst hier und hast ein Auto)"
      },
      "typ": "antragsteller"
    },
    {
      "id": "dav",
      "label": {
        "de": "Dienstabteilung Verkehr (DAV), Parkkartenservice",
        "en": "Traffic Services Division (DAV), permit office",
        "ls": "Das Verkehrs-Amt der Stadt"
      },
      "typ": "behoerde",
      "einheit_ref": "SiD-dav"
    },
    {
      "id": "stapo",
      "label": {
        "de": "Stadtpolizei Zürich (Verkehrskontrolle)",
        "en": "Zurich City Police (enforcement)",
        "ls": "Die Stadt-Polizei"
      },
      "typ": "behoerde",
      "einheit_ref": "SiD-stapo"
    },
    {
      "id": "statthalter",
      "label": {
        "de": "Statthalteramt / Bezirksrat Zürich",
        "en": "District governor's office (appeals)",
        "ls": "Eine Stelle vom Kanton für Beschwerden"
      },
      "typ": "gericht"
    }
  ],
  "schritte": [
    {
      "id": "start",
      "typ": "start",
      "akteur": "halter",
      "label": {
        "de": "Wohnsitz in blauer Zone + Auto",
        "en": "Residence in blue zone + vehicle",
        "ls": "Du wohnst in einer blauen Zone und hast ein Auto"
      }
    },
    {
      "id": "voraussetzungen-pruefen",
      "typ": "input",
      "akteur": "halter",
      "label": {
        "de": "Voraussetzungen selbst prüfen",
        "en": "Self-check eligibility",
        "ls": "Du schaust: Passt das für dich?"
      },
      "beschreibung": {
        "de": "Hauptwohnsitz in der blauen Zone (Meldebestätigung); Halter:in oder Dauernutzer:in des Fahrzeugs; Fahrzeug muss zugelassen sein.",
        "en": "Main residence in the blue zone, vehicle holder or permanent user, vehicle registered with licence plate.",
        "ls": "Du brauchst: Deine Wohn-Adresse in der blauen Zone. Du bist Besitzer vom Auto. Das Auto hat ein Kontrollschild."
      },
      "dauer_est": { "min": 10, "max": 30, "einheit": "minuten", "typ": "durchlauf" },
      "quelle": "q-stz-parkkarten"
    },
    {
      "id": "antrag-stellen",
      "typ": "input",
      "akteur": "halter",
      "label": {
        "de": "Antrag online stellen",
        "en": "Submit application online",
        "ls": "Du füllst das Formular im Internet aus"
      },
      "beschreibung": {
        "de": "Über das Online-Portal der Dienstabteilung Verkehr. Papiereingabe weiterhin möglich, dauert aber länger.",
        "en": "Via the DAV online portal. Paper submission still possible but slower."
      },
      "dauer_est": { "min": 15, "max": 30, "einheit": "minuten", "typ": "durchlauf" },
      "unterlagen": [
        { "label": { "de": "Kopie Fahrzeugausweis", "en": "Copy of vehicle registration" }, "pflicht": true },
        { "label": { "de": "Meldebestätigung / Wohnsitznachweis", "en": "Proof of residence" }, "pflicht": true },
        { "label": { "de": "Bei Firmenfahrzeug: Bestätigung des Dauernutzungsrechts", "en": "For company cars: permanent-use confirmation" }, "pflicht": false }
      ],
      "quelle": "q-stz-online"
    },
    {
      "id": "pruefung",
      "typ": "prozess",
      "akteur": "dav",
      "label": {
        "de": "Antrag prüfen (Wohnsitz, Halterschaft, Zone)",
        "en": "Check application (residence, holdership, zone)"
      },
      "beschreibung": {
        "de": "Die DAV gleicht die Angaben mit dem Einwohnerregister und dem Fahrzeugregister ab. Bei klaren Fällen vollautomatisiert."
      },
      "dauer_est": { "min": 1, "max": 10, "einheit": "arbeitstage", "typ": "bearbeitung" }
    },
    {
      "id": "vollstaendig",
      "typ": "entscheidung",
      "akteur": "dav",
      "label": {
        "de": "Unterlagen vollständig?",
        "en": "Application complete?",
        "ls": "Sind alle Angaben da?"
      }
    },
    {
      "id": "nachfrist",
      "typ": "loop",
      "akteur": "halter",
      "label": {
        "de": "Fehlende Unterlagen nachliefern",
        "en": "Submit missing documents",
        "ls": "Fehlendes nachreichen"
      },
      "dauer_est": { "min": 1, "max": 14, "einheit": "kalendertage", "typ": "durchlauf" }
    },
    {
      "id": "berechtigt",
      "typ": "entscheidung",
      "akteur": "dav",
      "label": {
        "de": "Berechtigt?",
        "en": "Entitled?",
        "ls": "Darfst du die Karte bekommen?"
      }
    },
    {
      "id": "rechnung",
      "typ": "prozess",
      "akteur": "dav",
      "label": {
        "de": "Rechnung zustellen",
        "en": "Issue invoice",
        "ls": "Du bekommst eine Rechnung"
      },
      "dauer_est": { "min": 1, "max": 5, "einheit": "arbeitstage", "typ": "bearbeitung" },
      "kosten_chf": {
        "min": 300,
        "max": 780,
        "anmerkung": {
          "de": "Jahresgebühr. Seit 2024: CHF 300 für Standardfahrzeuge, höhere Tarife für schwere/grossflächige Fahrzeuge. Bei anteiliger Dauer entsprechend pro-rata.",
          "en": "Annual fee. Since 2024: CHF 300 for standard vehicles, higher tariffs for heavy/oversized vehicles."
        }
      }
    },
    {
      "id": "bezahlen",
      "typ": "input",
      "akteur": "halter",
      "label": {
        "de": "Rechnung bezahlen",
        "en": "Pay invoice",
        "ls": "Du zahlst die Rechnung"
      },
      "dauer_est": { "min": 1, "max": 30, "einheit": "kalendertage", "typ": "durchlauf" }
    },
    {
      "id": "aktivierung",
      "typ": "prozess",
      "akteur": "dav",
      "label": {
        "de": "Kennzeichen im Parkkartensystem aktivieren",
        "en": "Activate licence plate in permit system",
        "ls": "Dein Kontrollschild kommt in den Computer"
      },
      "beschreibung": {
        "de": "Ab Aktivierung ist das Fahrzeug in der registrierten Zone dauerparkberechtigt. Kontrollen erfolgen durch Kennzeichen-Abgleich mit dem System.",
        "en": "Once activated, the vehicle is permanently authorised in the registered zone; enforcement is done via plate matching."
      },
      "dauer_est": { "min": 1, "max": 2, "einheit": "arbeitstage", "typ": "bearbeitung" }
    },
    {
      "id": "ablehnung",
      "typ": "prozess",
      "akteur": "dav",
      "label": {
        "de": "Antrag ablehnen (mit Begründung)",
        "en": "Reject application (with reasons)",
        "ls": "Das Amt sagt: Nein. Und schreibt warum."
      }
    },
    {
      "id": "einsprache-moeglich",
      "typ": "entscheidung",
      "akteur": "halter",
      "label": {
        "de": "Rekurs einreichen?",
        "en": "File appeal?",
        "ls": "Willst du dich beschweren?"
      }
    },
    {
      "id": "rekurs",
      "typ": "prozess",
      "akteur": "statthalter",
      "label": {
        "de": "Rekurs beim Statthalteramt",
        "en": "Appeal to district governor",
        "ls": "Beschwerde bei der Kantonsstelle"
      },
      "dauer_est": { "min": 2, "max": 9, "einheit": "monate", "typ": "durchlauf" }
    },
    {
      "id": "kontrolle",
      "typ": "warten",
      "akteur": "stapo",
      "label": {
        "de": "Laufende Kontrolle durch Stadtpolizei",
        "en": "Ongoing police enforcement",
        "ls": "Die Polizei schaut immer wieder, ob dein Auto eingetragen ist"
      },
      "beschreibung": {
        "de": "Über Kennzeichen-Scanner. Keine separate Handlung der Halter:in nötig — die Parkberechtigung gilt einfach."
      }
    },
    {
      "id": "ende-aktiv",
      "typ": "ende",
      "akteur": "halter",
      "label": {
        "de": "Parkkarte aktiv (1 Jahr)",
        "en": "Permit active (1 year)",
        "ls": "Deine Park-Karte funktioniert jetzt. Ein Jahr lang."
      }
    },
    {
      "id": "ende-abgelehnt",
      "typ": "ende",
      "akteur": "halter",
      "label": {
        "de": "Antrag rechtskräftig abgelehnt",
        "en": "Application rejected (final)",
        "ls": "Du bekommst keine Park-Karte"
      }
    }
  ],
  "flow": [
    { "von": "start", "nach": "voraussetzungen-pruefen" },
    { "von": "voraussetzungen-pruefen", "nach": "antrag-stellen" },
    { "von": "antrag-stellen", "nach": "pruefung" },
    { "von": "pruefung", "nach": "vollstaendig" },
    { "von": "vollstaendig", "nach": "nachfrist", "bedingung": "nein", "label": { "de": "unvollständig", "en": "incomplete" } },
    { "von": "nachfrist", "nach": "pruefung" },
    { "von": "vollstaendig", "nach": "berechtigt", "bedingung": "ja", "label": { "de": "vollständig", "en": "complete" } },
    { "von": "berechtigt", "nach": "rechnung", "bedingung": "ja" },
    { "von": "berechtigt", "nach": "ablehnung", "bedingung": "nein" },
    { "von": "rechnung", "nach": "bezahlen" },
    { "von": "bezahlen", "nach": "aktivierung" },
    { "von": "aktivierung", "nach": "kontrolle" },
    { "von": "kontrolle", "nach": "ende-aktiv" },
    { "von": "ablehnung", "nach": "einsprache-moeglich" },
    { "von": "einsprache-moeglich", "nach": "rekurs", "bedingung": "ja" },
    { "von": "einsprache-moeglich", "nach": "ende-abgelehnt", "bedingung": "nein" },
    { "von": "rekurs", "nach": "berechtigt", "label": { "de": "Neubeurteilung", "en": "re-evaluation" } }
  ],
  "meta": {
    "erstellt": "2026-04-24",
    "aktualisiert": "2026-04-24",
    "maintainer": "malkreide",
    "lizenz": "CC-BY-4.0"
  }
}
