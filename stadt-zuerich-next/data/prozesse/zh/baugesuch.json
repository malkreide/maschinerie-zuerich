      "depends_on": [
        7
      ],
      "type": "entscheidung"
    },
    {
      "step_id": 9,
      "actor": "amt-baubewilligungen",
      "label": {
        "de": "Einsprachen behandeln",
        "en": "Process objections"
      },
      "depends_on": [
        {
          "step_id": 8,
          "condition": {
            "de": "ja"
          }
        }
