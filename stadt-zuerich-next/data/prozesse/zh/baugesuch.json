      },
      "depends_on": [
        10
      ],
      "type": "prozess"
    },
    {
      "step_id": 12,
      "actor": "amt-baubewilligungen",
      "label": {
        "de": "Bewilligung erteilen?",
        "en": "Grant permit?",
        "ls": "Erlaubnis – ja oder nein?"
      },
      "depends_on": [
        11
      ],
      "type": "entscheidung"
    },
    {
      "step_id": 13,
      "actor": "amt-baubewilligungen",
      "label": {
        "de": "Baubewilligung erteilen (evtl. mit Auflagen)",
        "en": "Grant permit (possibly with conditions)",
        "ls": "Amt sagt Ja"
      },
      "depends_on": [
        {
          "step_id": 12,
          "condition": {
            "de": "ja"
          }
        }
      ],
      "type": "prozess"
    },
    {
      "step_id": 14,
      "actor": "amt-baubewilligungen",
      "label": {
        "de": "Gesuch abweisen",
        "en": "Reject application",
        "ls": "Amt sagt Nein"
      },
      "depends_on": [
        {
          "step_id": 12,
          "condition": {
            "de": "nein"
          }
        }
      ],
      "type": "prozess"
    },
    {
      "step_id": 15,
      "actor": "bauherr",
      "label": {
        "de": "Rekurs einlegen?",
        "en": "File appeal?",
        "ls": "Willst du dagegen klagen?"
      },
      "depends_on": [
        14
      ],
      "type": "entscheidung"
    },
    {
      "step_id": 16,
      "actor": "baurekurs",
      "label": {
        "de": "Rekursverfahren Baurekursgericht",
        "en": "Appeal proceedings"
      },
      "depends_on": [
        {
          "step_id": 15,
          "condition": {
            "de": "ja"
          }
        }
      ],
      "type": "loop",
      "loops_back_to": [
        12
      ]
    },
    {
      "step_id": 17,
      "actor": "bauherr",
      "label": {
        "de": "Bauen möglich (nach Rechtskraft)",
        "en": "Construction may begin (after legal force)",
        "ls": "Du darfst bauen"
      },
      "depends_on": [
        13
      ],
      "type": "ende"
    },
    {
      "step_id": 18,
      "actor": "bauherr",
      "label": {
        "de": "Verfahren rechtskräftig abgeschlossen (ohne Bewilligung)",
