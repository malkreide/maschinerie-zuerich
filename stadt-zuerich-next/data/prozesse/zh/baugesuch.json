      "depends_on": [
        {
          "step_id": 5,
          "condition": {
            "de": "vollständig",
            "en": "complete"
          }
        }
      ],
      "type": "prozess"
    },
    {
      "step_id": 8,
      "actor": "nachbarn",
      "label": {
        "de": "Einsprachen erhoben?",
