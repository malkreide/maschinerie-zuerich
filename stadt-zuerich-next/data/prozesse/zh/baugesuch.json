      "depends_on": [
        9,
        {
          "step_id": 8,
          "condition": {
            "de": "nein"
          }
        }
      ],
      "type": "prozess"
    },
    {
      "step_id": 11,
      "actor": "hochbauamt",
      "label": {
        "de": "Materielle Prüfung (BZO, PBG, Lärm, Brandschutz …)",
