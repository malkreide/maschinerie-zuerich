      },
      "depends_on": [
        2
      ],
      "reference_ids": [
        1
      ],
      "type": "input",
      "source_id": "q-ebaugesuch"
    },
    {
      "step_id": 4,
      "actor": "amt-baubewilligungen",
      "label": {
        "de": "Formelle Vorprüfung",
        "en": "Formal completeness check"
      },
      "depends_on": [
        3
      ],
      "type": "prozess",
      "description": {
        "de": "Prüfung, ob das Gesuch vollständig und bearbeitbar ist."
      }
    },
    {
      "step_id": 5,
      "actor": "amt-baubewilligungen",
      "label": {
        "de": "Unterlagen vollständig?",
        "en": "Application complete?",
        "ls": "Sind alle Papiere da?"
      },
      "depends_on": [
        4
      ],
      "type": "entscheidung"
    },
    {
      "step_id": 6,
      "actor": "bauherr",
      "label": {
        "de": "Unterlagen nachliefern",
