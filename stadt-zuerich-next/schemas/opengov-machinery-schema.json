{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/malkreide/maschinerie-zuerich/main/stadt-zuerich-next/schemas/opengov-machinery-schema.json",
  "title": "OpenGov-Machinery-Schema",
  "description": "Portables Schema zur Beschreibung der Organisationsstruktur von öffentlichen Verwaltungen. Erlaubt föderierte Verknüpfungen zu anderen Instanzen.",
  "type": "object",
  "required": ["_meta", "center", "departments", "units"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["schemaVersion", "stand"],
      "properties": {
        "schemaVersion": { "type": "number" },
        "stand": { "type": "string", "format": "date", "description": "Datenstand (ISO-Datum, z.B. 2026-04-20). Die Stadt-/Jahresangabe für Budget steht in budgetStand." },
        "budgetStand": { "type": "string" },
        "license": { "type": "string", "description": "Lizenz der Daten, z.B. 'CC-BY 4.0'." },
        "quellen": { "type": "array", "items": { "type": "string" } },
        "hinweise": { "type": "array", "items": { "type": "string" } }
      }
    },
    "organization": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string", "description": "Global eindeutige ID, z.B. 'ch.zuerich.stadt'" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["city", "canton", "federal", "other"] },
        "parentOrganizationId": { "type": "string", "description": "ID der übergeordneten Organisation (z.B. Kanton für eine Stadt)" },
        "parentOrganizationUrl": { "type": "string", "format": "uri", "description": "URL der data.json der übergeordneten Organisation" },
        "logoUrl": { "type": "string", "format": "uri" },
        "primaryColor": { "type": "string" }
      }
    },
    "center": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["center"] },
        "note": { "type": "string" }
      }
    },
    "departments": {
      "type": "array",
      "items": { "$ref": "#/definitions/Department" }
    },
    "units": {
      "type": "array",
      "items": { "$ref": "#/definitions/Unit" }
    },
    "beteiligungen": {
      "type": "array",
      "items": { "$ref": "#/definitions/Beteiligung" }
    },
    "relationships": {
      "type": "array",
      "description": "Nicht-hierarchische Verknüpfungen zwischen Einheiten — z.B. Wahl/Aufsicht ohne Verwaltungsunterstellung. Ergänzt die hierarchische parent-Beziehung, ersetzt sie nicht.",
      "items": { "$ref": "#/definitions/Relationship" }
    },
    "aussenbeziehungen": {
      "type": "array",
      "description": "Aussenbeziehungen der Stadt, die keine Kapitalbeteiligungen sind: Städtepartnerschaften, Netzwerk-Mitgliedschaften, regionale Kooperationen, subventionierte Vereine.",
      "items": { "$ref": "#/definitions/Aussenbeziehung" }
    }
  },
  "definitions": {
    "Aussenbeziehung": {
      "type": "object",
      "required": ["id", "name", "typ"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "typ": {
          "type": "string",
          "enum": ["partnerstadt", "netzwerk", "regionale_kooperation", "subventionierter_verein"],
          "description": "partnerstadt = Städtepartnerschaft; netzwerk = Mitgliedschaft in einem Städte-/Institutionennetzwerk; regionale_kooperation = regionale Koordinations-/Kooperationsbeziehung; subventionierter_verein = Verein mit Subventions-/Leistungsvertrag."
        },
        "sektor": {
          "type": "string",
          "enum": ["energie", "verkehr", "finanzen", "wohnen", "kultur", "soziales", "freizeit", "gesundheit"]
        },
        "zweck": { "type": "string" },
        "rolle": { "type": "string" },
        "seit": { "type": "string", "description": "Beginn der Beziehung (Jahr)." },
        "referenz": {
          "type": "object",
          "required": ["label", "url"],
          "properties": {
            "label": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "quelle": { "type": "string" },
        "stand": { "type": "string" },
        "provenance": {
          "type": "string",
          "enum": ["publiziert", "aggregiert", "geschaetzt", "manuell", "api", "pdf", "demo"]
        }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["from", "to", "type"],
      "properties": {
        "from": { "type": "string", "description": "ID der ausführenden/aufsehenden Einheit (Department- oder Unit-ID)." },
        "to": { "type": "string", "description": "ID der verknüpften Einheit (Department- oder Unit-ID)." },
        "type": {
          "type": "string",
          "enum": ["wahl_und_aufsicht", "fachlich_politische_verknuepfung"],
          "description": "wahl_und_aufsicht = Wahl und Aufsicht ohne Verwaltungsunterstellung (z.B. Gemeinderat über Ombudsstelle); fachlich_politische_verknuepfung = fachliche/politische Verknüpfung ohne Unterstellung (z.B. Departement ↔ verwaltungsunabhängige Behörde)."
        },
        "description": { "type": "string", "description": "Kurze Erläuterung der Beziehung (de)." }
      }
    },
    "Budget": {
      "type": "object",
      "required": ["jahr", "typ", "aufwand", "ertrag", "nettoaufwand"],
      "properties": {
        "jahr": { "type": "number" },
        "typ": { "type": "string" },
        "aufwand": { "type": "number" },
        "ertrag": { "type": "number" },
        "nettoaufwand": { "type": "number" }
      }
    },
    "Fte": {
      "type": "object",
      "required": ["schaetzung"],
      "properties": {
        "schaetzung": { "type": "number" },
        "einheit": { "type": "string" }
      }
    },
    "FederationLink": {
      "type": "object",
      "required": ["targetId", "targetUrl", "label"],
      "properties": {
        "targetId": { "type": "string" },
        "targetUrl": { "type": "string", "format": "uri", "description": "URL des externen data.json oder UI" },
        "label": { "type": "string" }
      }
    },
    "Department": {
      "type": "object",
      "required": ["id", "name", "vorsteher"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vorsteher": { "type": "string" },
        "budget": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/Budget" }] },
        "fte": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/Fte" }] },
        "federationLinks": {
          "type": "array",
          "items": { "$ref": "#/definitions/FederationLink" }
        }
      }
    },
    "Unit": {
      "type": "object",
      "required": ["id", "parent", "name", "kind"],
      "properties": {
        "id": { "type": "string" },
        "parent": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "type": "string", "enum": ["unit", "staff", "extern", "committee", "spezial"] },
        "budget": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/Budget" }] },
        "fte": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/Fte" }] },
        "federationLinks": {
          "type": "array",
          "items": { "$ref": "#/definitions/FederationLink" }
        }
      }
    },
    "Beteiligung": {
      "type": "object",
      "required": ["id", "name", "verbunden"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "verbunden": { "type": "string" },
        "rechtsform": {
          "type": "string",
          "enum": ["ag", "stiftung", "genossenschaft", "oeffentlich-rechtlich", "verein"],
          "description": "Rechtsform der Beteiligung."
        },
        "beteiligungsart": {
          "type": "string",
          "enum": ["strategisch", "finanziell"],
          "description": "strategisch = öffentlicher Auftrag/Steuerungsinteresse; finanziell = primär Kapitalanlage."
        },
        "sektor": {
          "type": "string",
          "enum": ["energie", "verkehr", "finanzen", "wohnen", "kultur", "soziales", "freizeit", "gesundheit"],
          "description": "Aufgabenbereich der Beteiligung."
        },
        "zweck": { "type": "string", "description": "Kurzbeschreibung des öffentlichen Zwecks (de)." },
        "quelle": { "type": "string", "description": "Beleg-URL (z. B. Beteiligungsbericht)." },
        "stand": { "type": "string", "description": "Datenstand (Jahr oder ISO-Datum)." },
        "provenance": {
          "type": "string",
          "enum": ["publiziert", "aggregiert", "geschaetzt", "manuell", "api", "pdf", "demo"],
          "description": "Maschinenlesbare Datenherkunft."
        },
        "beziehungen": {
          "type": "array",
          "description": "Typisierte Beziehungen der Stadt zur Organisation (Trägerschaft, VR-Vertretung, Subvention, Leistungsauftrag). Bindende Werte nur als referenz-Deep-Link, nie als gerenderter Wert (Kardinalregel).",
          "items": { "$ref": "#/definitions/BeteiligungBeziehung" }
        }
      }
    },
    "BeteiligungBeziehung": {
      "type": "object",
      "required": ["typ"],
      "properties": {
        "typ": {
          "type": "string",
          "enum": ["traegerschaft", "mit_traegerschaft", "vr_vertretung", "subvention", "leistungsauftrag"],
          "description": "traegerschaft = öffentlich-rechtliche Trägerschaft; mit_traegerschaft = gemeinsame Trägerschaft (z. B. mit Kanton); vr_vertretung = Verwaltungs-/Stiftungsrats-Vertretung; subvention = Subventions-/Leistungsvertrag; leistungsauftrag = Leistungsauftrag ohne Subventionscharakter."
        },
        "rolle": { "type": "string", "description": "Rolle der Stadt (de), z. B. «Trägerin bzw. Stifterin»." },
        "mittraeger": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Mit-Träger bei gemeinsamer Trägerschaft, z. B. [\"Kanton Zürich\"]."
        },
        "referenz": {
          "type": "object",
          "required": ["label", "url"],
          "properties": {
            "label": { "type": "string" },
            "url": { "type": "string", "format": "uri", "description": "Deep-Link auf die amtliche Grundlage." }
          },
          "description": "Deep-Link auf die amtliche Grundlage — kein gerenderter bindender Wert (Kardinalregel)."
        }
      }
    }
  }
}
